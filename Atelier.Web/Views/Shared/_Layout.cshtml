@using Atelier.Web.Services
@using Atelier.Web.ViewModels
@{
    var layout = ViewData["Layout"] as LayoutViewModel ?? new LayoutViewModel();
    var title = ViewData["MetaTitle"]?.ToString() ?? ViewData["Title"]?.ToString() ?? layout.SiteName;
    var description = ViewData["MetaDescription"]?.ToString();
    var canonical = SeoHelper.BuildCanonicalUrl(Context.Request, ViewData["CanonicalUrl"]?.ToString());
    var ogImage = ViewData["OpenGraphImage"]?.ToString();
    var ogType = ViewData["OpenGraphType"]?.ToString() ?? "website";
    var organizationSchema = ViewData["OrganizationSchema"]?.ToString();
    var websiteSchema = ViewData["WebsiteSchema"]?.ToString();
    var pageSchema = ViewData["PageSchema"]?.ToString();
    var productSchema = ViewData["ProductSchema"]?.ToString();
    var breadcrumbSchema = ViewData["BreadcrumbSchema"]?.ToString();
    var robots = ViewData["Robots"]?.ToString() ?? "index,follow,max-image-preview:large";
}
<!DOCTYPE html>
<html lang="fa" dir="rtl">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="theme-color" content="#0b1018" />
    <meta name="robots" content="@robots" />
    <title>@title</title>
    @if (!string.IsNullOrWhiteSpace(description)) { <meta name="description" content="@description" /> }
    <link rel="canonical" href="@canonical" />
    <meta property="og:title" content="@title" /><meta property="og:type" content="@ogType" /><meta property="og:url" content="@canonical" />
    @if (!string.IsNullOrWhiteSpace(description)) { <meta property="og:description" content="@description" /><meta name="twitter:description" content="@description" /> }
    @if (!string.IsNullOrWhiteSpace(ogImage)) { <meta property="og:image" content="@ogImage" /><meta name="twitter:image" content="@ogImage" /> }
    <meta name="twitter:card" content="summary_large_image" /><meta name="twitter:title" content="@title" />
    @if (!string.IsNullOrWhiteSpace(layout.FaviconUrl)) { <link rel="icon" href="@layout.FaviconUrl" /> }
    @foreach (var schema in new[] { organizationSchema, websiteSchema, pageSchema, productSchema, breadcrumbSchema })
    {
        if (!string.IsNullOrWhiteSpace(schema)) { <script type="application/ld+json">@Html.Raw(schema)</script> }
    }
    <link rel="preconnect" href="https://fonts.googleapis.com" /><link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Vazirmatn:wght@300;400;500;600;700;800;900&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>
<a class="skip-link" href="#main-content">رفتن به محتوای اصلی</a>
<div class="announcement">ارسال مطمئن به سراسر ایران <span>•</span> مشاوره تخصصی رایگان پیش از خرید</div>
<header class="site-header" data-header>
    <div class="container-xxl site-header__inner">
        <a class="wordmark" href="/" aria-label="صفحه اصلی mr2008.ir"><span>MR</span><b>2008</b><small>.IR</small></a>
        <nav class="primary-nav" id="primary-navigation" aria-label="منوی اصلی">
            <a href="/categories">فروشگاه قطعات</a><a href="/engine-parts">قطعات موتور</a><a href="/filters-consumables">لوازم مصرفی</a><a href="/blog">راهنمای خرید</a><a href="/pages/about-us">درباره ما</a>
        </nav>
        <div class="header-actions"><a class="header-search" href="/categories#catalogQuery" aria-label="جست‌وجو">⌕</a><a class="header-consult" href="/pages/contact-us">مشاوره خرید</a><button class="nav-toggle" type="button" aria-label="نمایش منو" aria-controls="primary-navigation" aria-expanded="false">☰</button></div>
    </div>
</header>
<main class="site-main" id="main-content">@RenderBody()</main>
<footer class="site-footer">
    <div class="container-xxl footer-grid">
        <div><a class="wordmark wordmark--footer" href="/"><span>MR</span><b>2008</b><small>.IR</small></a><p>مرجع تخصصی انتخاب و خرید قطعات پژو ۲۰۰۸؛ با تمرکز بر اصالت، مشاوره فنی و تجربه خرید مطمئن.</p></div>
        <div><h3>دسترسی سریع</h3><a href="/categories">فروشگاه</a><a href="/blog">راهنمای خرید</a><a href="/pages/about-us">درباره ما</a></div>
        <div><h3>خدمات مشتریان</h3><a href="/pages/contact-us">تماس با ما</a><a href="/pages/faq">سؤالات متداول</a><a href="/pages/contact-us">استعلام قطعه</a></div>
        <div><h3>اطلاعات تماس</h3><span>@layout.Phone</span><span>@layout.Email</span><span>@layout.Address</span></div>
    </div>
    <div class="container-xxl footer-bottom"><span>© @DateTime.Now.Year mr2008.ir</span><span>انتخاب مطمئن برای پژو ۲۰۰۸</span></div>
</footer>
<script src="~/js/site.js" asp-append-version="true"></script>
@await RenderSectionAsync("Scripts", required: false)
</body></html>
