@model IReadOnlyList<Atelier.Web.ViewModels.BreadcrumbItemViewModel>

@if (Model.Count > 0)
{
    <nav aria-label="breadcrumb" class="breadcrumb-nav">
        <ol class="breadcrumb">
            @for (var i = 0; i < Model.Count; i++)
            {
                var item = Model[i];
                var isLast = i == Model.Count - 1;
                <li class="breadcrumb-item @(isLast ? "active" : string.Empty)" @(isLast ? "aria-current=\"page\"" : string.Empty)>
                    @if (!string.IsNullOrWhiteSpace(item.Url) && !isLast)
                    {
                        <a href="@item.Url">@item.Title</a>
                    }
                    else
                    {
                        @item.Title
                    }
                </li>
            }
        </ol>
    </nav>
}
