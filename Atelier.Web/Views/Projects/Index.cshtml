@using Atelier.Web.Services
@model Atelier.Web.ViewModels.ProjectListViewModel
@{
    const string cardSizes = "(min-width: 1200px) 360px, (min-width: 992px) 33vw, (min-width: 768px) 50vw, 100vw";
}

<div class="container-xxl py-4 page-shell">
    @await Html.PartialAsync("_Breadcrumbs", Model.Breadcrumbs)

    <section class="hero-card mb-4">
        <h1 class="h4 fw-bold mb-2">پروژه های اجرایی</h1>
        <p class="text-muted mb-0">نمونه ای از پروژه های اجرا شده در حوزه نما، کف و سازه های ترمووود.</p>
    </section>

    @if (!Model.Projects.Any())
    {
        <div class="content-card text-center">
            <p class="text-muted mb-0">هنوز پروژه ای ثبت نشده است.</p>
        </div>
    }
    else
    {
        <div class="row g-4">
            @foreach (var project in Model.Projects)
            {
                <div class="col-12 col-md-6 col-lg-4">
                    <article class="card-soft h-100 project-card hover-float">
                        @if (!string.IsNullOrWhiteSpace(project.ImageUrl))
                        {
                            <div class="project-card-media">
                                @{
                                    var projectSrc = ImageHelper.BuildResizedUrl(project.ImageUrl, 900) ?? project.ImageUrl;
                                    var projectSrcSet = ImageHelper.BuildSrcSet(project.ImageUrl, ImageHelper.FeatureBreakpoints);
                                }
                                <img src="@projectSrc" srcset="@projectSrcSet" sizes="@cardSizes" alt="@project.ImageAltText" loading="lazy" decoding="async" />
                            </div>
                        }
                        <div class="p-3 d-flex flex-column gap-2 h-100">
                            <h2 class="h6 fw-bold mb-0">@project.Title</h2>
                            @if (!string.IsNullOrWhiteSpace(project.Summary))
                            {
                                <p class="text-muted small flex-grow-1">@project.Summary</p>
                            }
                            else
                            {
                                <p class="text-muted small flex-grow-1 mb-0">جزئیات این پروژه به زودی تکمیل می‌شود.</p>
                            }
                            <div class="d-flex justify-content-between align-items-center">
                                <a class="btn btn-outline-dark btn-sm" href="@project.Url">جزئیات پروژه</a>
                                <span class="badge rounded-pill bg-light text-muted">گالری</span>
                            </div>
                        </div>
                    </article>
                </div>
            }
        </div>
    }
</div>
