@using Atelier.Web.Services
@model Atelier.Web.ViewModels.HomeViewModel
@{
    const string cardSizes = "(min-width: 1200px) 300px, (min-width: 768px) 50vw, 100vw";
}

<section class="hero" aria-labelledby="hero-title">
    <div class="hero__glow"></div>
    <div class="container-xxl hero__inner">
        <div class="hero__copy reveal">
            <span class="eyebrow"><i></i> مرکز تخصصی قطعات پژو ۲۰۰۸</span>
            <h1 id="hero-title">قطعه درست.<br><span>با اطمینان کامل.</span></h1>
            <p>قطعات اصلی و باکیفیت پژو ۲۰۰۸، با بررسی فنی پیش از خرید، ضمانت اصالت و ارسال مطمئن به سراسر ایران.</p>
            <div class="hero__actions">
                <a class="btn-primary-premium" href="/categories">مشاهده قطعات <span>←</span></a>
                <a class="btn-ghost-premium" href="/pages/contact-us">مشاوره فنی</a>
            </div>
            <div class="trust-inline">
                <span>✓ تضمین اصالت</span><span>✓ تطبیق با خودرو</span><span>✓ پشتیبانی تخصصی</span>
            </div>
        </div>
        <div class="hero__visual reveal" data-parallax>
            <div class="hero__ring"></div>
            <div class="hero__number">2008</div>
            <div class="hero__part-card hero__part-card--one"><b>EP6</b><small>قطعات موتور</small></div>
            <div class="hero__part-card hero__part-card--two"><b>OEM</b><small>اصالت تأییدشده</small></div>
        </div>
    </div>
</section>

<section class="trust-strip">
    <div class="container-xxl trust-strip__grid">
        <div><b>اصالت کالا</b><span>تضمین کیفیت و سلامت قطعه</span></div>
        <div><b>انتخاب دقیق</b><span>تطبیق قطعه با مدل خودرو</span></div>
        <div><b>ارسال سراسری</b><span>بسته‌بندی ایمن و قابل پیگیری</span></div>
        <div><b>مشاوره واقعی</b><span>پاسخ‌گویی توسط کارشناس قطعات</span></div>
    </div>
</section>

<main class="container-xxl home-content">
    <section class="vehicle-finder reveal">
        <div><span class="eyebrow">جست‌وجوی هوشمند</span><h2>قطعه مناسب را سریع پیدا کنید</h2><p>نام قطعه، کد فنی یا دسته‌بندی موردنظر را جست‌وجو کنید.</p></div>
        <form action="/categories" method="get" class="finder-form">
            <label><span>خودرو</span><select name="vehicle"><option>پژو ۲۰۰۸</option></select></label>
            <label class="finder-search"><span>نام یا کد قطعه</span><input name="q" placeholder="مثلاً فیلتر روغن یا 1109..." /></label>
            <button type="submit" aria-label="جست‌وجو">جست‌وجو</button>
        </form>
    </section>

    <section class="home-section reveal">
        <div class="section-heading"><div><span class="eyebrow">دسترسی سریع</span><h2>دسته‌بندی قطعات</h2></div><a href="/categories">همه دسته‌بندی‌ها ←</a></div>
        <div class="category-grid">
            @foreach (var category in Model.TopCategories)
            {
                <a class="category-tile" href="@category.Url">
                    @if (!string.IsNullOrWhiteSpace(category.ImageUrl))
                    {
                        var src = ImageHelper.BuildResizedUrl(category.ImageUrl, 720) ?? category.ImageUrl;
                        <img src="@src" alt="@category.ImageAltText" loading="lazy" decoding="async" />
                    }
                    <div><h3>@category.Name</h3><p>@category.Summary</p><span>مشاهده قطعات ←</span></div>
                </a>
            }
        </div>
    </section>

    <section class="home-section reveal">
        <div class="section-heading"><div><span class="eyebrow">پیشنهاد کارشناسان</span><h2>قطعات منتخب</h2></div><a href="/categories">مشاهده همه ←</a></div>
        <div class="products-grid">
            @foreach (var product in Model.FeaturedProducts)
            {
                <article class="premium-product-card">
                    <a href="@product.Url" class="premium-product-card__media">
                        @if (!string.IsNullOrWhiteSpace(product.ImageUrl))
                        {
                            var src = ImageHelper.BuildResizedUrl(product.ImageUrl, 720) ?? product.ImageUrl;
                            <img src="@src" sizes="@cardSizes" alt="@product.ImageAltText" loading="lazy" decoding="async" />
                        }
                        <span class="auth-badge">ضمانت اصالت</span>
                    </a>
                    <div class="premium-product-card__body"><small>مناسب پژو ۲۰۰۸</small><h3><a href="@product.Url">@product.Name</a></h3><div><b>@product.PriceDisplay</b><a href="@product.Url" aria-label="مشاهده محصول">←</a></div></div>
                </article>
            }
        </div>
    </section>

    <section class="expert-cta reveal">
        <div><span class="eyebrow eyebrow--light">پیش از خرید مطمئن شوید</span><h2>نمی‌دانید کدام قطعه مناسب خودروی شماست؟</h2><p>کد VIN یا تصویر قطعه را برای ما بفرستید؛ کارشناس فنی، گزینه درست را بررسی می‌کند.</p></div>
        <a href="/pages/contact-us">دریافت مشاوره رایگان <span>←</span></a>
    </section>
</main>
