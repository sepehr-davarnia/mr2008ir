@using Atelier.Web.Services
@model Atelier.Web.ViewModels.BlogListViewModel
@{
    const string cardSizes = "(min-width: 1200px) 360px, (min-width: 992px) 33vw, (min-width: 768px) 50vw, 100vw";
}
<div class="container-xxl py-4 page-shell">
    @await Html.PartialAsync("_Breadcrumbs", Model.Breadcrumbs)

    <section class="hero-card mb-4">
        <h1 class="h4 fw-bold mb-2">بلاگ تخصصی ترمووود</h1>
        <p class="text-muted mb-0">جدیدترین نکات درباره انتخاب، نصب و نگهداری ترمووود را بخوانید.</p>
    </section>

    @if (!Model.Posts.Any())
    {
        <div class="content-card text-center">
            <h2 class="h6 fw-bold mb-2">هنوز مقاله ای منتشر نشده است.</h2>
            <p class="text-muted mb-0">به زودی مطالب تازه منتشر می کنیم.</p>
        </div>
    }
    else
    {
        <div class="row g-4">
            @foreach (var post in Model.Posts)
            {
                <div class="col-12 col-md-6 col-lg-4">
                    <article class="blog-card h-100">
                        @if (!string.IsNullOrWhiteSpace(post.FeaturedImageUrl))
                        {
                            var postSrc = ImageHelper.BuildResizedUrl(post.FeaturedImageUrl, 840) ?? post.FeaturedImageUrl;
                            var postSrcSet = ImageHelper.BuildSrcSet(post.FeaturedImageUrl, ImageHelper.FeatureBreakpoints);
                            <img src="@postSrc" srcset="@postSrcSet" sizes="@cardSizes" alt="@post.Title" loading="lazy" decoding="async" />
                        }
                        <div class="p-3">
                            <div class="text-muted small mb-2">@LocalizationHelper.FormatDate(post.PublishedAt)</div>
                            <h2 class="h6 fw-bold">@post.Title</h2>
                            <p class="text-muted small mb-3">@post.Excerpt</p>
                            <a class="btn btn-outline-dark btn-sm" asp-controller="Blog" asp-action="Details" asp-route-slug="@post.Slug">ادامه مقاله</a>
                        </div>
                    </article>
                </div>
            }
        </div>
    }
</div>
