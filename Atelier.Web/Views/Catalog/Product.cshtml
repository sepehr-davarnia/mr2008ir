@model Atelier.Web.ViewModels.ProductDetailViewModel
@{
    const string heroSizes = "(min-width: 1200px) 540px, (min-width: 992px) 50vw, 100vw";
    const string gallerySizes = "(min-width: 1200px) 25vw, (min-width: 992px) 33vw, 50vw";
    var layout = ViewData["Layout"] as Atelier.Web.ViewModels.LayoutViewModel ?? new Atelier.Web.ViewModels.LayoutViewModel();
    var phoneHref = string.IsNullOrWhiteSpace(layout.Phone) ? null : "tel:" + new string(layout.Phone.Where(c => char.IsDigit(c) || c == '+').ToArray());
}

<div class="container-xxl py-4 page-shell">
    @await Html.PartialAsync("_Breadcrumbs", Model.Breadcrumbs)

    <section class="hero-card product-hero mb-4 reveal">
        <div class="row align-items-center g-4">
            <div class="col-12 col-lg-7">
                <h1 class="h4 fw-bold mb-2">@Model.Title</h1>
                <div class="fw-semibold mb-2">قیمت: @Model.PriceDisplay</div>
                @if (!string.IsNullOrWhiteSpace(Model.ShortDescription))
                {
                    <p class="text-muted mb-0">@Model.ShortDescription</p>
                }
                <div class="product-confidence mt-4"><span>✓ ضمانت اصالت</span><span>✓ بررسی سازگاری</span><span>✓ ارسال مطمئن</span></div>
                <div class="product-purchase mt-4">
                    @if (Model.CanPurchaseOnline)
                    {
                        <form method="post" action="/cart/add" data-cart-add>
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="productId" value="@Model.Id" />
                            <input type="hidden" name="returnUrl" value="@Context.Request.Path" />
                            <button class="purchase-primary" type="submit"><span>افزودن به سبد خرید</span><small>خرید آنلاین و ثبت امن سفارش</small></button>
                        </form>
                    }
                    @if (phoneHref is not null)
                    {
                        <a class="purchase-call" href="@phoneHref"><span>تماس برای خرید</span><small dir="ltr">@layout.Phone</small></a>
                    }
                </div>
                <p class="purchase-microcopy">پرداخت آنلاین از درگاه امن انجام می‌شود؛ در صورت تردید، پیش از خرید برای بررسی VIN تماس بگیرید.</p>
            </div>
            @if (!string.IsNullOrWhiteSpace(Model.HeroImageUrl))
            {
                <div class="col-12 col-lg-5">
                    @{
                        var heroSrc = ImageHelper.BuildResizedUrl(Model.HeroImageUrl, 1200) ?? Model.HeroImageUrl;
                        var heroSrcSet = ImageHelper.BuildSrcSet(Model.HeroImageUrl, ImageHelper.HeroBreakpoints);
                    }
                    <div class="hero-media hero-media-inline">
                        <img class="rounded-4 w-100" src="@heroSrc" srcset="@heroSrcSet" sizes="@heroSizes" alt="@(Model.HeroImageAltText ?? Model.Title)" loading="eager" fetchpriority="high" decoding="async" />
                    </div>
                </div>
            }
        </div>
    </section>

    <div class="row g-4">
        <div class="col-12 col-lg-7">
            <div class="content-card h-100 reveal">
                <h2 class="h6 fw-bold mb-3">معرفی محصول</h2>
                @if (!string.IsNullOrWhiteSpace(Model.Description))
                {
                    <p class="text-muted mb-0">@Model.Description</p>
                }
                else
                {
                    <p class="text-muted mb-0">برای دریافت مشخصات فنی این محصول با ما تماس بگیرید.</p>
                }
            </div>
        </div>
        <div class="col-12 col-lg-5">
            <div class="content-card h-100 reveal">
                <h2 class="h6 fw-bold mb-3">مشخصات فنی</h2>
                @if (Model.Specifications.Any())
                {
                    <div class="spec-grid">
                        @foreach (var spec in Model.Specifications)
                        {
                            <div class="spec-item">
                                <div class="fw-semibold">@spec.Label</div>
                                <div class="text-muted small">@spec.Value</div>
                            </div>
                        }
                    </div>
                }
                else
                {
                    <p class="text-muted mb-0">مشخصات فنی این محصول در حال تکمیل است.</p>
                }
            </div>
        </div>
    </div>

    <section class="content-card mt-4 reveal" aria-labelledby="compatibility-title">
        <div class="product-detail-grid">
            <div>
                <span class="eyebrow">شناسه‌های فنی</span>
                <h2 class="h5 fw-bold mt-2">اطلاعات قطعه</h2>
                <dl class="technical-identifiers">
                    @if (!string.IsNullOrWhiteSpace(Model.Brand)) { <div><dt>برند</dt><dd>@Model.Brand</dd></div> }
                    @if (!string.IsNullOrWhiteSpace(Model.Manufacturer)) { <div><dt>سازنده</dt><dd>@Model.Manufacturer</dd></div> }
                    @if (!string.IsNullOrWhiteSpace(Model.OemPartNumber)) { <div><dt>شماره OEM</dt><dd dir="ltr">@Model.OemPartNumber</dd></div> }
                    @if (!string.IsNullOrWhiteSpace(Model.TechnicalPartNumber)) { <div><dt>کد فنی</dt><dd dir="ltr">@Model.TechnicalPartNumber</dd></div> }
                    @if (!string.IsNullOrWhiteSpace(Model.AlternatePartNumbers)) { <div><dt>کدهای جایگزین</dt><dd dir="ltr">@Model.AlternatePartNumbers</dd></div> }
                </dl>
            </div>
            <div>
                <span class="eyebrow">تطبیق خودرو</span>
                <h2 id="compatibility-title" class="h5 fw-bold mt-2">سازگاری تأییدشده</h2>
                @if (!Model.CompatibleVehicles.Any())
                {
                    <div class="compatibility-empty">برای اطمینان از سازگاری، پیش از خرید تماس بگیرید.</div>
                }
                else
                {
                    <div class="compatibility-list">
                        @foreach (var vehicle in Model.CompatibleVehicles)
                        {
                            <article><div class="compatibility-icon">✓</div><div><b>@vehicle.Make @vehicle.Model — @vehicle.Trim</b><span>@vehicle.YearFrom تا @(vehicle.YearTo?.ToString() ?? "اکنون") · @vehicle.Engine</span>@if (vehicle.RequiresVinCheck) { <em>تأیید VIN پیش از ارسال</em> }@if (!string.IsNullOrWhiteSpace(vehicle.Note)) { <small>@vehicle.Note</small> }</div></article>
                        }
                    </div>
                }
            </div>
        </div>
    </section>

    @if (Model.Gallery.Any())
    {
        <section class="mt-4">
            <div class="section-title">تصاویر محصول</div>
            <div class="row g-3">
                @foreach (var media in Model.Gallery)
                {
                    <div class="col-6 col-lg-3">
                        @{
                            var mediaSrc = ImageHelper.BuildResizedUrl(media.Url, 720) ?? media.Url;
                            var mediaSrcSet = ImageHelper.BuildSrcSet(media.Url, ImageHelper.GalleryBreakpoints);
                        }
                        <img class="img-fluid rounded-4" src="@mediaSrc" srcset="@mediaSrcSet" sizes="@gallerySizes" alt="@(media.AltText ?? Model.Title)" loading="lazy" decoding="async" />
                    </div>
                }
            </div>
        </section>
    }
</div>
