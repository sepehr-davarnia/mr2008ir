@model Atelier.Web.ViewModels.CategoryViewModel
@{
    const string categorySizes = "(min-width: 1200px) 480px, (min-width: 992px) 50vw, 100vw";
}

<div class="container-xxl py-4 page-shell">
    @await Html.PartialAsync("_Breadcrumbs", Model.Breadcrumbs)

    <section class="hero-card mb-4 reveal">
        <h1 class="h4 fw-bold mb-2">دسته بندی محصولات</h1>
        <p class="text-muted mb-0">با نام یا کد قطعه جست‌وجو کنید و نتیجه را بر اساس سال، موتور و تریم خودرو تطبیق دهید.</p>
        <form method="get" action="/categories" class="catalog-search mt-4" role="search">
            <label class="visually-hidden" for="catalogQuery">جست‌وجوی قطعه</label>
            <input id="catalogQuery" name="q" value="@Model.Query" maxlength="100" placeholder="نام قطعه یا کد فنی را وارد کنید" />
            <select name="year" aria-label="سال مدل"><option value="">همه سال‌ها</option>@foreach (var option in Model.YearOptions) { <option value="@option" selected="@(Model.VehicleYear == option)">@option</option> }</select>
            <select name="engine" aria-label="موتور"><option value="">همه موتورها</option>@foreach (var option in Model.EngineOptions) { <option value="@option" selected="@(Model.Engine == option)">@option</option> }</select>
            <select name="trim" aria-label="تریم"><option value="">همه تریم‌ها</option>@foreach (var option in Model.TrimOptions) { <option value="@option" selected="@(Model.Trim == option)">@option</option> }</select>
            <button type="submit">پیدا کردن قطعه سازگار</button>
        </form>
    </section>

    @if (Model.HasDiscoveryFilter)
    {
        <section class="mb-5 reveal" aria-live="polite">
            <div class="section-title">قطعات مطابق جست‌وجو و خودروی شما</div>
            @if (!Model.SearchResults.Any())
            {
                <div class="content-card text-center"><h2 class="h6 fw-bold">قطعه‌ای پیدا نشد</h2><p class="text-muted mb-0">نام کوتاه‌تر، کد فنی یا دسته‌بندی قطعه را امتحان کنید.</p></div>
            }
            else
            {
                <div class="row g-4">
                    @foreach (var product in Model.SearchResults)
                    {
                        <div class="col-12 col-md-6 col-lg-4"><article class="card-soft product-card h-100">
                            @if (!string.IsNullOrWhiteSpace(product.ImageUrl)) { <div class="product-card-media"><img src="@product.ImageUrl" alt="@product.ImageAltText" loading="lazy" /></div> }
                            <div class="p-3"><h2 class="h6 fw-bold">@product.Name</h2><p class="text-muted small">@product.ShortDescription</p><div class="fw-semibold mb-3">@product.PriceDisplay</div><div class="product-card-actions"><a class="btn btn-dark btn-sm" href="@product.Url">مشاهده محصول</a>@if (product.CanPurchaseOnline) { <form method="post" action="/cart/add" data-cart-add>@Html.AntiForgeryToken()<input type="hidden" name="productId" value="@product.Id" /><input type="hidden" name="returnUrl" value="@Context.Request.Path@Context.Request.QueryString" /><button class="btn btn-primary btn-sm" type="submit"><span>افزودن به سبد</span></button></form> }</div></div>
                        </article></div>
                    }
                </div>
            }
        </section>
    }

    <div class="row g-4">
        @foreach (var category in Model.Categories)
        {
            <div class="col-12 col-lg-6">
                <div class="card-soft h-100 category-card hover-float reveal">
                    <a class="text-decoration-none" href="@category.Url">
                        <div class="category-card-media">
                            @if (!string.IsNullOrWhiteSpace(category.ImageUrl))
                            {
                                var categorySrc = ImageHelper.BuildResizedUrl(category.ImageUrl, 960) ?? category.ImageUrl;
                                var categorySrcSet = ImageHelper.BuildSrcSet(category.ImageUrl, ImageHelper.FeatureBreakpoints);
                                <img src="@categorySrc" srcset="@categorySrcSet" sizes="@categorySizes" alt="@category.ImageAltText" loading="lazy" decoding="async" />
                            }
                            else
                            {
                                <div class="category-card-placeholder"></div>
                            }
                        </div>
                        <div class="p-3 d-flex flex-column gap-1">
                            <h2 class="h6 fw-bold mb-1">@category.Name</h2>
                            <p class="text-muted small mb-0">@category.Summary</p>
                        </div>
                    </a>
                    @if (category.Children.Any())
                    {
                        <div class="p-3 pt-0">
                            <div class="d-flex flex-wrap gap-2 pill-list">
                                @foreach (var child in category.Children)
                                {
                                    <a href="@child.Url">@child.Name</a>
                                }
                            </div>
                        </div>
                    }
                </div>
            </div>
        }
    </div>
</div>
