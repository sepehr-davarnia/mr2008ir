@model Atelier.Web.Areas.Admin.ViewModels.BlogPostFormViewModel
@{
    Layout = "/Areas/Admin/Views/Shared/_AdminLayout.cshtml";
    ViewData["Title"] = "ایجاد مقاله";
}

<div class="container-fluid py-4" dir="rtl">
    <div class="admin-form-card">
        <div class="mb-4">
            <h1 class="h5 fw-bold mb-1">ایجاد مقاله جدید</h1>
            <span asp-validation-for="FeaturedMediaId" class="text-danger small"></span>
            <p class="text-muted mb-0">با نوشتن یک مقاله کوتاه، به دیده شدن برند کمک کنید.</p>
        </div>
        <form method="post" class="admin-form" data-admin-form>
            @Html.AntiForgeryToken()
            <div class="mb-3">
                <label class="form-label fw-semibold">تصویر شاخص</label>
                <input type="hidden" asp-for="FeaturedMediaId" id="FeaturedMediaId" />
                <div class="d-flex align-items-center gap-3">
                    <div class="border rounded-4 bg-light d-flex align-items-center justify-content-center" style="width: 120px; height: 90px;">
                        <img id="featuredImagePreview" src="@Model.FeaturedMediaUrl" class="img-fluid rounded-3 @(string.IsNullOrWhiteSpace(Model.FeaturedMediaUrl) ? "d-none" : string.Empty)" alt="پیش‌نمایش تصویر شاخص" />
                        <span id="featuredImagePlaceholder" class="text-muted small @(string.IsNullOrWhiteSpace(Model.FeaturedMediaUrl) ? string.Empty : "d-none")">بدون تصویر</span>
                    </div>
                    <button type="button" class="btn btn-outline-primary admin-action-btn" onclick="openMediaManager({ targetInputId: 'FeaturedMediaId', previewImageId: 'featuredImagePreview', placeholderId: 'featuredImagePlaceholder', selectedMediaId: @(Model.FeaturedMediaId ?? 0) });">
                        انتخاب تصویر شاخص
                    </button>
                </div>
                <span asp-validation-for="FeaturedMediaId" class="text-danger small"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Slug" class="form-label"></label>
                <input asp-for="Slug" class="form-control admin-input" placeholder="اگر خالی بماند، خودکار ساخته میشود" />
                <span asp-validation-for="Slug" class="text-danger small"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Excerpt" class="form-label"></label>
                <textarea asp-for="Excerpt" class="form-control admin-input" rows="3" placeholder="خلاصه کوتاه مقاله"></textarea>
                <span asp-validation-for="Excerpt" class="text-danger small"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Content" class="form-label"></label>
                <textarea asp-for="Content" class="form-control admin-input" rows="8" placeholder="متن کامل مقاله"></textarea>
                <span asp-validation-for="Content" class="text-danger small"></span>
            </div>

           

            <div class="mb-3">
                <label asp-for="MetaTitle" class="form-label"></label>
                <input asp-for="MetaTitle" class="form-control admin-input" placeholder="عنوان برای موتورهای جستجو" />
                <span asp-validation-for="MetaTitle" class="text-danger small"></span>
            </div>

            <div class="mb-4">
                <label asp-for="MetaDescription" class="form-label"></label>
                <textarea asp-for="MetaDescription" class="form-control admin-input" rows="3" placeholder="توضیح کوتاه برای موتورهای جستجو"></textarea>
                <span asp-validation-for="MetaDescription" class="text-danger small"></span>
            </div>

            <div class="d-flex flex-column flex-md-row gap-2">
                <button type="submit" class="btn btn-success admin-action-btn" data-loading-text="در حال ذخیره...">ذخیره مقاله</button>
                <a class="btn btn-outline-secondary admin-action-btn" asp-area="Admin" asp-controller="Blog" asp-action="Index">بازگشت</a>
            </div>
        </form>
    </div>
</div>
