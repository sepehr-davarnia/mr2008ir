@using Atelier.Domain.Enums
@using Atelier.Web.Services
@model Atelier.Web.Areas.Admin.ViewModels.OrderDetailsViewModel
@{
    Layout = "/Areas/Admin/Views/Shared/_AdminLayout.cshtml";
    ViewData["Title"] = $"سفارش {Model.Number}";
    string StatusText(OrderStatus status) => status switch { OrderStatus.AwaitingPayment => "در انتظار پرداخت", OrderStatus.AwaitingReview => "در انتظار بررسی", OrderStatus.Confirmed => "تأیید شده", OrderStatus.Preparing => "در حال آماده‌سازی", OrderStatus.Shipped => "ارسال شده", OrderStatus.Completed => "تکمیل شده", _ => "لغو شده" };
}
@if (TempData["SuccessMessage"] is string message) { <div class="alert alert-success">@message</div> }
<div class="row g-4"><div class="col-12 col-xl-8"><div class="admin-card mb-4"><div class="d-flex justify-content-between gap-3 mb-4"><div><h2 class="h5 fw-bold" dir="ltr">@Model.Number</h2><p class="text-muted mb-0">ثبت‌شده در @LocalizationHelper.FormatDate(Model.CreatedAt)</p></div><span class="badge text-bg-light align-self-start">@StatusText(Model.Status)</span></div>
<div class="table-responsive"><table class="table align-middle"><thead><tr><th>محصول</th><th>قیمت واحد</th><th>تعداد</th><th>جمع</th></tr></thead><tbody>@foreach (var item in Model.Items) { <tr><td>@item.ProductName</td><td>@LocalizationHelper.FormatPrice(item.UnitPrice, PriceType.Fixed)</td><td>@item.Quantity</td><td><b>@LocalizationHelper.FormatPrice(item.LineTotal, PriceType.Fixed)</b></td></tr> }</tbody><tfoot><tr><th colspan="3">جمع کالاها</th><th>@LocalizationHelper.FormatPrice(Model.Total, PriceType.Fixed)</th></tr></tfoot></table></div></div>
<div class="admin-card mb-4"><h2 class="h6 fw-bold mb-3">نشانی ارسال</h2><p>@Model.Province، @Model.City، @Model.Address</p>@if (!string.IsNullOrWhiteSpace(Model.PostalCode)) { <p class="text-muted">کد پستی: <span dir="ltr">@Model.PostalCode</span></p> }@if (!string.IsNullOrWhiteSpace(Model.CustomerNote)) { <hr /><h3 class="h6">یادداشت مشتری</h3><p class="mb-0">@Model.CustomerNote</p> }</div>
<div class="admin-card"><h2 class="h6 fw-bold mb-3">تاریخچه سفارش</h2><ol class="mb-0">@foreach (var step in Model.History) { <li class="mb-2"><b>@StatusText(step.Status)</b> <small class="text-muted">@LocalizationHelper.FormatDate(step.CreatedAt)</small>@if (!string.IsNullOrWhiteSpace(step.Note)) { <div class="small">@step.Note</div> }</li> }</ol></div></div>
<div class="col-12 col-xl-4"><div class="admin-card mb-4"><h2 class="h6 fw-bold mb-3">اطلاعات مشتری</h2><b>@Model.CustomerName</b><a class="d-block mt-2" href="tel:@Model.Phone" dir="ltr">@Model.Phone</a></div><div class="admin-card mb-4"><h2 class="h6 fw-bold mb-3">پرداخت</h2><span class="badge @(Model.PaymentStatus == PaymentStatus.Paid ? "text-bg-success" : "text-bg-warning")">@Model.PaymentStatus</span>@foreach (var payment in Model.Payments) { <div class="small mt-3"><b>@payment.Gateway</b><div>کد مرجع: <span dir="ltr">@(payment.ReferenceId ?? "—")</span></div><div>کد درگاه: @payment.GatewayCode</div></div> }</div><div class="admin-card"><h2 class="h6 fw-bold mb-3">تغییر وضعیت و ارسال</h2><form method="post" asp-action="UpdateStatus"><input type="hidden" name="id" value="@Model.Id" />@Html.AntiForgeryToken()<select class="form-select mb-3" name="status">@foreach (var status in Enum.GetValues<OrderStatus>()) { <option value="@status" selected="@(status == Model.Status)">@StatusText(status)</option> }</select><input class="form-control mb-2" name="carrier" value="@Model.Carrier" placeholder="شرکت حمل (مثلاً پست)" /><input class="form-control mb-3" name="trackingNumber" value="@Model.TrackingNumber" dir="ltr" placeholder="کد رهگیری مرسوله" /><button class="btn btn-primary w-100" type="submit">ذخیره وضعیت</button></form></div></div></div>
