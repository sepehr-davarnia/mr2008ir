@model Atelier.Web.Areas.Admin.ViewModels.ProjectEditViewModel
@{
    Layout = "/Areas/Admin/Views/Shared/_AdminLayout.cshtml";
    ViewData["Title"] = "ویرایش پروژه";
}

<div class="container-fluid py-4" dir="rtl">
    <div class="admin-form-card">
        <div class="mb-4">
            <h1 class="h5 fw-bold mb-1">ویرایش پروژه</h1>
            <p class="text-muted mb-0">اطلاعات پروژه را به‌روزرسانی کنید.</p>
        </div>

        @if (TempData["SuccessMessage"] is string successMessage)
        {
            <div class="alert alert-success admin-alert" role="alert">
                <i class="bi bi-check-circle"></i>
                <span>@successMessage</span>
            </div>
        }
        else if (TempData["ErrorMessage"] is string errorMessage)
        {
            <div class="alert alert-danger admin-alert" role="alert">
                <i class="bi bi-exclamation-triangle"></i>
                <span>@errorMessage</span>
            </div>
        }

        <form method="post" class="admin-form" data-admin-form>
            @Html.AntiForgeryToken()
            <input type="hidden" asp-for="Id" />

            <div class="mb-3">
                <label class="form-label fw-semibold">تصویر شاخص</label>
                <input type="hidden" asp-for="FeaturedMediaId" id="FeaturedMediaId" />
                <div class="d-flex align-items-center gap-3">
                    <div class="border rounded-4 bg-light d-flex align-items-center justify-content-center" style="width: 140px; height: 100px;">
                        <img id="featuredImagePreview" src="@Model.FeaturedMediaUrl" class="img-fluid rounded-3 @(string.IsNullOrWhiteSpace(Model.FeaturedMediaUrl) ? "d-none" : string.Empty)" alt="پیش‌نمایش تصویر شاخص" />
                        <span id="featuredImagePlaceholder" class="text-muted small @(string.IsNullOrWhiteSpace(Model.FeaturedMediaUrl) ? string.Empty : "d-none")">بدون تصویر</span>
                    </div>
                    <button type="button" class="btn btn-outline-primary admin-action-btn" onclick="openMediaManager({ targetInputId: 'FeaturedMediaId', previewImageId: 'featuredImagePreview', placeholderId: 'featuredImagePlaceholder', selectedMediaId: @(Model.FeaturedMediaId ?? 0) });">
                        انتخاب تصویر
                    </button>
                </div>
                <span asp-validation-for="FeaturedMediaId" class="text-danger small"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Title" class="form-label"></label>
                <input asp-for="Title" class="form-control admin-input" />
                <span asp-validation-for="Title" class="text-danger small"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Slug" class="form-label"></label>
                <input asp-for="Slug" class="form-control admin-input" />
                <span asp-validation-for="Slug" class="text-danger small"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Description" class="form-label"></label>
                <textarea asp-for="Description" class="form-control admin-input" rows="5"></textarea>
                <span asp-validation-for="Description" class="text-danger small"></span>
            </div>

            <div class="mb-4">
                <label asp-for="IsPublished" class="form-label"></label>
                <select asp-for="IsPublished" class="form-select admin-input">
                    <option value="false">پیش‌نویس</option>
                    <option value="true">منتشر شده</option>
                </select>
            </div>

            @if (Model.Id.HasValue)
            {
                <div class="mb-4">
                    <div class="d-flex justify-content-between align-items-center mb-2">
                        <label class="form-label fw-semibold mb-0">گالری تصاویر</label>
                        <button type="button" class="btn btn-outline-primary btn-sm admin-action-btn" onclick="openMediaManager({ targetInputId: 'NewGalleryMediaId', formId: 'addProjectMediaForm' });">
                            افزودن تصویر
                        </button>
                    </div>
                    <p class="text-muted small mb-3">تصاویر با متن جایگزین معتبر انتخاب کنید تا در کارت پروژه و صفحه اصلی نمایش داده شوند.</p>

                    @if (!Model.Gallery.Any())
                    {
                        <div class="border rounded-4 p-3 text-center bg-light">
                            <p class="mb-0 text-muted small">هنوز تصویری به گالری اضافه نشده است.</p>
                        </div>
                    }
                    else
                    {
                        <div class="row g-3">
                            @foreach (var media in Model.Gallery)
                            {
                                <div class="col-12 col-md-6 col-xl-4">
                                    <div class="border rounded-4 h-100 p-2 bg-light d-flex flex-column gap-2">
                                        <div class="ratio ratio-4x3 rounded-3 overflow-hidden bg-white">
                                            <img src="@media.Url" alt="@media.AltText" class="img-fluid" loading="lazy" />
                                        </div>
                                        <div class="d-flex justify-content-between align-items-center">
                                            <span class="text-muted small text-truncate" title="@media.AltText">@media.AltText</span>
                                            <form method="post" asp-area="Admin" asp-controller="Projects" asp-action="RemoveGalleryMedia" onsubmit="return confirm('آیا از حذف تصویر مطمئن هستید؟');">
                                                @Html.AntiForgeryToken()
                                                <input type="hidden" name="id" value="@Model.Id" />
                                                <input type="hidden" name="mediaId" value="@media.Id" />
                                                <button type="submit" class="btn btn-outline-danger btn-sm admin-action-btn">
                                                    <i class="bi bi-trash"></i>
                                                </button>
                                            </form>
                                        </div>
                                    </div>
                                </div>
                            }
                        </div>
                    }

                    <form id="addProjectMediaForm" method="post" asp-area="Admin" asp-controller="Projects" asp-action="AddGalleryMedia" class="mt-3 d-none">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="id" value="@Model.Id" />
                        <input type="hidden" name="newGalleryMediaId" id="NewGalleryMediaId" />
                    </form>
                </div>
            }

            <div class="d-flex flex-column flex-md-row gap-2">
                <button type="submit" class="btn btn-success admin-action-btn" data-loading-text="در حال ذخیره...">ذخیره تغییرات</button>
                <a class="btn btn-outline-secondary admin-action-btn" asp-area="Admin" asp-controller="Projects" asp-action="Index">بازگشت</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
