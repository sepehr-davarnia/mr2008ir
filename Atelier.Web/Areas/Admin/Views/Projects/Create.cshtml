@model Atelier.Web.Areas.Admin.ViewModels.ProjectEditViewModel
@{
    Layout = "/Areas/Admin/Views/Shared/_AdminLayout.cshtml";
    ViewData["Title"] = "ایجاد پروژه";
}

<div class="container-fluid py-4" dir="rtl">
    <div class="admin-form-card">
        <div class="mb-4">
            <h1 class="h5 fw-bold mb-1">ایجاد پروژه جدید</h1>
            <p class="text-muted mb-0">اطلاعات پروژه را وارد کنید.</p>
        </div>

        <form method="post" class="admin-form" data-admin-form>
            @Html.AntiForgeryToken()

            <div class="mb-3">
                <label class="form-label fw-semibold">تصویر شاخص</label>
                <input type="hidden" asp-for="FeaturedMediaId" id="FeaturedMediaId" />
                <div class="d-flex align-items-center gap-3">
                    <div class="border rounded-4 bg-light d-flex align-items-center justify-content-center" style="width: 140px; height: 100px;">
                        <img id="featuredImagePreview" src="@Model.FeaturedMediaUrl" class="img-fluid rounded-3 @(string.IsNullOrWhiteSpace(Model.FeaturedMediaUrl) ? "d-none" : string.Empty)" alt="پیش‌نمایش تصویر شاخص" />
                        <span id="featuredImagePlaceholder" class="text-muted small @(string.IsNullOrWhiteSpace(Model.FeaturedMediaUrl) ? string.Empty : "d-none")">بدون تصویر</span>
                    </div>
                    <button type="button" class="btn btn-outline-primary admin-action-btn" onclick="openMediaManager({ targetInputId: 'FeaturedMediaId', previewImageId: 'featuredImagePreview', placeholderId: 'featuredImagePlaceholder', selectedMediaId: @(Model.FeaturedMediaId ?? 0) });">
                        انتخاب تصویر
                    </button>
                </div>
                <span asp-validation-for="FeaturedMediaId" class="text-danger small"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Title" class="form-label"></label>
                <input asp-for="Title" class="form-control admin-input" />
                <span asp-validation-for="Title" class="text-danger small"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Slug" class="form-label"></label>
                <input asp-for="Slug" class="form-control admin-input" placeholder="اگر خالی بماند، خودکار ساخته می‌شود" />
                <span asp-validation-for="Slug" class="text-danger small"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Description" class="form-label"></label>
                <textarea asp-for="Description" class="form-control admin-input" rows="5"></textarea>
                <span asp-validation-for="Description" class="text-danger small"></span>
            </div>

            <div class="mb-4">
                <label asp-for="IsPublished" class="form-label"></label>
                <select asp-for="IsPublished" class="form-select admin-input">
                    <option value="false">پیش‌نویس</option>
                    <option value="true">منتشر شده</option>
                </select>
            </div>

            <div class="d-flex flex-column flex-md-row gap-2">
                <button type="submit" class="btn btn-success admin-action-btn" data-loading-text="در حال ذخیره...">ذخیره پروژه</button>
                <a class="btn btn-outline-secondary admin-action-btn" asp-area="Admin" asp-controller="Projects" asp-action="Index">بازگشت</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
