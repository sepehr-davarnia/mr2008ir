@model IReadOnlyList<Atelier.Web.Areas.Admin.ViewModels.ProjectListItemViewModel>
@{
    Layout = "/Areas/Admin/Views/Shared/_AdminLayout.cshtml";
    ViewData["Title"] = "پروژه‌ها";
}

<div class="container-fluid py-4" dir="rtl">
    <div class="admin-card">
        <div class="d-flex flex-column flex-lg-row align-items-lg-center justify-content-between gap-3 mb-4">
            <div>
                <h1 class="h5 fw-bold mb-1">پروژه‌ها</h1>
                <p class="text-muted mb-0">نمونه‌کارها و پروژه‌های اجرا شده.</p>
            </div>
            <a class="btn btn-primary admin-action-btn" asp-area="Admin" asp-controller="Projects" asp-action="Create">
                افزودن پروژه
            </a>
        </div>

        @if (TempData["SuccessMessage"] is string successMessage)
        {
            <div class="alert alert-success admin-alert" role="alert">
                <i class="bi bi-check-circle"></i>
                <span>@successMessage</span>
            </div>
        }

        @if (!Model.Any())
        {
            <div class="alert alert-light border mb-0">
                هنوز پروژه‌ای ثبت نشده است.
            </div>
        }
        else
        {
            <div class="table-responsive">
                <table class="table align-middle">
                    <thead class="table-light">
                        <tr>
                            <th>عنوان پروژه</th>
                            <th>اسلاگ</th>
                            <th>وضعیت</th>
                            <th class="text-end">عملیات</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var project in Model)
                        {
                            <tr>
                                <td>@project.Title</td>
                                <td>@project.Slug</td>
                                <td>
                                    <span class="badge @(project.IsPublished ? "bg-success" : "bg-secondary")">
                                        @(project.IsPublished ? "منتشر شده" : "پیش‌نویس")
                                    </span>
                                </td>
                                <td class="text-end">
                                    <a class="btn btn-outline-primary btn-sm" asp-area="Admin" asp-controller="Projects" asp-action="Edit" asp-route-id="@project.Id">ویرایش</a>
                                    <form method="post" class="d-inline" asp-area="Admin" asp-controller="Projects" asp-action="@(project.IsPublished ? "Unpublish" : "Publish")">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="id" value="@project.Id" />
                                        <button type="submit" class="btn btn-outline-secondary btn-sm">
                                            @(project.IsPublished ? "بازگشت به پیش‌نویس" : "انتشار")
                                        </button>
                                    </form>
                                    <form method="post" class="d-inline" asp-area="Admin" asp-controller="Projects" asp-action="Delete" onsubmit="return confirm('آیا از حذف این پروژه مطمئن هستید؟');">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="id" value="@project.Id" />
                                        <button type="submit" class="btn btn-outline-danger btn-sm">حذف</button>
                                    </form>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>
</div>
