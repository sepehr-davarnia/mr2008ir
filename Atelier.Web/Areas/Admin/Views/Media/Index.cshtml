@model Atelier.Web.Areas.Admin.ViewModels.MediaListViewModel
@{
    Layout = "/Areas/Admin/Views/Shared/_AdminLayout.cshtml";
    ViewData["Title"] = "مدیریت رسانه‌ها";
}

<div class="container-fluid py-4" dir="rtl">
    <div class="admin-card">
        <div class="d-flex flex-column flex-lg-row align-items-lg-center justify-content-between gap-3 mb-4">
            <div>
                <h1 class="h5 fw-bold mb-1">رسانه‌های ذخیره‌شده</h1>
                <p class="text-muted mb-0">لیست فایل‌های ذخیره‌شده برای محصولات.</p>
            </div>
        </div>

        @if (!Model.Items.Any())
        {
            <div class="alert alert-light border mb-0">
                هنوز فایلی ذخیره نشده است.
            </div>
        }
        else
        {
            <div class="table-responsive">
                <table class="table align-middle">
                    <thead class="table-light">
                        <tr>
                            <th>شناسه</th>
                            <th>عنوان</th>
                            <th>نوع فایل</th>
                            <th>حجم</th>
                            <th>شناسه محصول</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model.Items)
                        {
                            <tr>
                                <td>@item.Id</td>
                                <td>@(string.IsNullOrWhiteSpace(item.Title) ? "-" : item.Title)</td>
                                <td>@(string.IsNullOrWhiteSpace(item.ContentType) ? "-" : item.ContentType)</td>
                                <td>@(item.FileSize is null ? "-" : $"{item.FileSize / 1024:N0} کیلوبایت")</td>
                                <td>@(item.ProductId?.ToString() ?? "-")</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>
</div>
