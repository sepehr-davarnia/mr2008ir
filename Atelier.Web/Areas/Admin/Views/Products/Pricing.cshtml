@using Atelier.Domain.Enums
@model Atelier.Web.Areas.Admin.ViewModels.ProductPricingIndexViewModel
@{
    Layout = "/Areas/Admin/Views/Shared/_AdminLayout.cshtml";
    ViewData["Title"] = "مدیریت قیمت‌ها";
}

<div class="container-fluid py-4" dir="rtl">
    <div class="admin-card mb-4 d-flex flex-column flex-lg-row align-items-lg-center justify-content-between gap-3">
        <div>
            <h1 class="h5 fw-bold mb-1">مدیریت قیمت محصولات</h1>
            <p class="text-muted mb-0">قیمت هر محصول را به‌روزرسانی کنید.</p>
        </div>
        <a class="btn btn-outline-secondary admin-action-btn" asp-area="Admin" asp-controller="Products" asp-action="Index">
            بازگشت به محصولات
        </a>
    </div>

    @if (TempData["SuccessMessage"] is string successMessage)
    {
        <div class="alert alert-success admin-alert" role="alert">
            <i class="bi bi-check-circle"></i>
            <span>@successMessage</span>
        </div>
    }

    @if (TempData["ErrorMessage"] is string errorMessage)
    {
        <div class="alert alert-danger admin-alert" role="alert">
            <i class="bi bi-exclamation-circle"></i>
            <span>@errorMessage</span>
        </div>
    }

    @if (!Model.Products.Any())
    {
        <div class="admin-card">
            <p class="mb-0 text-muted">محصولی برای تنظیم قیمت وجود ندارد.</p>
        </div>
    }
    else
    {
        <div class="admin-card">
            <div class="table-responsive">
                <table class="table align-middle">
                    <thead class="table-light">
                        <tr>
                            <th>نام محصول</th>
                            <th>وضعیت</th>
                            <th>قیمت فعلی</th>
                            <th class="text-end">به‌روزرسانی</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var product in Model.Products)
                        {
                            <tr>
                                <td class="fw-semibold">@product.Name</td>
                                <td>
                                    @switch (product.Status)
                                    {
                                        case ProductStatus.Published:
                                            <span class="badge bg-success">منتشر شده</span>
                                            break;
                                        case ProductStatus.Archived:
                                            <span class="badge bg-secondary">بایگانی</span>
                                            break;
                                        default:
                                            <span class="badge bg-warning text-dark">پیش‌نویس</span>
                                            break;
                                    }
                                </td>
                                <td>@product.PriceDisplay</td>
                                <td class="text-end">
                                    <form method="post" asp-area="Admin" asp-controller="Products" asp-action="UpdatePrice" class="d-flex gap-2 justify-content-end align-items-center flex-wrap">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="Id" value="@product.Id" />
                                        <input type="number" step="1000" min="0" name="Price" value="@(product.Price?.ToString("0") ?? string.Empty)" class="form-control admin-input w-auto" aria-label="قیمت جدید برای @product.Name" placeholder="مثال: 2500000" />
                                        <button type="submit" class="btn btn-success admin-action-btn btn-sm">ثبت قیمت</button>
                                        <button type="submit" name="IsContactPrice" value="true" class="btn btn-outline-secondary admin-action-btn btn-sm">قیمت تماس</button>
                                    </form>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    }
</div>
