@using Atelier.Domain.Enums
@model Atelier.Web.Areas.Admin.ViewModels.ProductCreateViewModel
@{
    Layout = "/Areas/Admin/Views/Shared/_AdminLayout.cshtml";
    ViewData["Title"] = "ایجاد محصول";
}

<div class="container-fluid py-4" dir="rtl">
    <div class="admin-form-card">
        <div class="mb-4">
            <h1 class="h5 fw-bold mb-1">ایجاد محصول جدید</h1>
            <p class="text-muted mb-0">اطلاعات پایه محصول را وارد کنید.</p>
        </div>

        <form method="post" class="admin-form" data-admin-form>
            @Html.AntiForgeryToken()

            <div class="mb-3">
                <label asp-for="Name" class="form-label"></label>
                <input asp-for="Name" class="form-control admin-input" placeholder="مثلاً میز جلو مبلی" />
                <span asp-validation-for="Name" class="text-danger small"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Slug" class="form-label"></label>
                <input asp-for="Slug" class="form-control admin-input" placeholder="اگر خالی بماند، خودکار ساخته می‌شود" />
                <span asp-validation-for="Slug" class="text-danger small"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Description" class="form-label"></label>
                <textarea asp-for="Description" class="form-control admin-input" rows="4" placeholder="توضیح کوتاهی درباره محصول"></textarea>
                <span asp-validation-for="Description" class="text-danger small"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Price" class="form-label"></label>
                <input asp-for="Price" class="form-control admin-input" type="number" step="1000" min="0" placeholder="مثلاً 2500000" />
                <span asp-validation-for="Price" class="text-danger small"></span>
            </div>

            <div class="row g-3 mb-3">
                <div class="col-md-6"><label asp-for="Brand" class="form-label"></label><input asp-for="Brand" class="form-control admin-input" /></div>
                <div class="col-md-6"><label asp-for="Manufacturer" class="form-label"></label><input asp-for="Manufacturer" class="form-control admin-input" /></div>
                <div class="col-md-6"><label asp-for="OemPartNumber" class="form-label"></label><input asp-for="OemPartNumber" class="form-control admin-input" dir="ltr" /></div>
                <div class="col-md-6"><label asp-for="TechnicalPartNumber" class="form-label"></label><input asp-for="TechnicalPartNumber" class="form-control admin-input" dir="ltr" /></div>
                <div class="col-12"><label asp-for="AlternatePartNumbers" class="form-label"></label><input asp-for="AlternatePartNumbers" class="form-control admin-input" dir="ltr" placeholder="کدها را با کاما جدا کنید" /></div>
            </div>

            <div class="row g-3 mb-3">
                <div class="col-md-6">
                    <label asp-for="CategoryIds" class="form-label"></label>
                    <select asp-for="CategoryIds" class="form-select admin-input" size="6" multiple>
                        @foreach (var option in Model.CategoryOptions) { <option value="@option.Id">@option.Label</option> }
                    </select>
                    <div class="form-text">برای انتخاب چند مورد، Ctrl یا Command را نگه دارید.</div>
                </div>
                <div class="col-md-6">
                    <label asp-for="VehicleIds" class="form-label"></label>
                    <select asp-for="VehicleIds" class="form-select admin-input" size="6" multiple>
                        @foreach (var option in Model.VehicleOptions) { <option value="@option.Id">@option.Label</option> }
                    </select>
                    <div class="form-check mt-2"><input asp-for="RequiresVinCheck" class="form-check-input" /><label asp-for="RequiresVinCheck" class="form-check-label"></label></div>
                </div>
            </div>

            <div class="mb-4">
                <label asp-for="Status" class="form-label"></label>
                <select asp-for="Status" class="form-select admin-input">
                    <option value="@ProductStatus.Draft">پیش‌نویس</option>
                    <option value="@ProductStatus.Published">منتشر شده</option>
                    <option value="@ProductStatus.Archived">بایگانی</option>
                </select>
            </div>

            <div class="d-flex flex-column flex-md-row gap-2">
                <button type="submit" class="btn btn-success admin-action-btn" data-loading-text="در حال ذخیره...">ذخیره محصول</button>
                <a class="btn btn-outline-secondary admin-action-btn" asp-area="Admin" asp-controller="Products" asp-action="Index">بازگشت</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
