@using Atelier.Domain.Enums
@model Atelier.Web.Areas.Admin.ViewModels.ProductIndexViewModel
@{
    Layout = "/Areas/Admin/Views/Shared/_AdminLayout.cshtml";
    ViewData["Title"] = "مدیریت محصولات";
}

<div class="container-fluid py-4" dir="rtl">
    <div class="admin-card mb-4">
        <div class="d-flex flex-column flex-lg-row align-items-lg-center justify-content-between gap-3">
            <div>
                <h1 class="h5 fw-bold mb-1">محصولات</h1>
                <p class="text-muted mb-0">فهرست محصولات فروشگاه را مدیریت کنید.</p>
            </div>
            <div class="d-flex flex-wrap gap-2">
                <a class="btn btn-outline-primary admin-action-btn" asp-area="Admin" asp-controller="Products" asp-action="Pricing">
                    <i class="bi bi-cash-coin"></i>
                    مدیریت قیمت‌ها
                </a>
                <a class="btn btn-success admin-action-btn" asp-area="Admin" asp-controller="Products" asp-action="Create">
                    <i class="bi bi-plus-circle"></i>
                    افزودن محصول
                </a>
            </div>
        </div>
    </div>

    <div class="admin-card mb-4">
        <form method="get" class="row g-2 align-items-end">
            <div class="col-12 col-lg-8">
                <label class="form-label">جستجو</label>
                <input type="text" name="search" value="@Model.Search" class="form-control admin-input" placeholder="نام یا اسلاگ محصول را وارد کنید" />
            </div>
            <div class="col-12 col-lg-4 d-grid">
                <button type="submit" class="btn btn-outline-primary admin-action-btn">نمایش نتایج</button>
            </div>
        </form>
    </div>

    @if (TempData["SuccessMessage"] is string successMessage)
    {
        <div class="alert alert-success admin-alert" role="alert">
            <i class="bi bi-check-circle"></i>
            <span>@successMessage</span>
        </div>
    }

    @if (!Model.Products.Any())
    {
        <div class="admin-card text-center">
            <h2 class="h6 fw-bold mb-2">هنوز محصولی ثبت نشده است.</h2>
            <p class="text-muted mb-3">برای شروع، یک محصول جدید اضافه کنید.</p>
            <a class="btn btn-success admin-action-btn" asp-area="Admin" asp-controller="Products" asp-action="Create">
                افزودن محصول
            </a>
        </div>
    }
    else
    {
        <div class="admin-card">
            <div class="table-responsive">
                <table class="table align-middle">
                    <thead class="table-light">
                        <tr>
                            <th>نام</th>
                            <th>وضعیت</th>
                            <th class="text-end">عملیات</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var product in Model.Products)
                        {
                            <tr>
                                <td class="fw-semibold">@product.Name</td>
                                <td>
                                    @switch (product.Status)
                                    {
                                        case ProductStatus.Published:
                                            <span class="badge bg-success">منتشر شده</span>
                                            break;
                                        case ProductStatus.Archived:
                                            <span class="badge bg-secondary">بایگانی</span>
                                            break;
                                        default:
                                            <span class="badge bg-warning text-dark">پیش‌نویس</span>
                                            break;
                                    }
                                </td>
                                <td class="text-end">
                                    <a class="btn btn-outline-primary btn-sm" asp-area="Admin" asp-controller="Products" asp-action="Edit" asp-route-id="@product.Id">ویرایش</a>
                                    <form method="post" asp-area="Admin" asp-controller="Products" asp-action="Delete" asp-route-id="@product.Id" class="d-inline" onsubmit="return confirm('آیا از حذف این محصول مطمئن هستید؟ این عمل قابل بازگشت نیست.');">
                                        @Html.AntiForgeryToken()
                                        <button type="submit" class="btn btn-outline-danger btn-sm">حذف</button>
                                    </form>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    }
</div>
