@model Atelier.Web.Areas.Admin.ViewModels.LoginViewModel
@{
    Layout = "/Areas/Admin/Views/Shared/_AdminAuthLayout.cshtml";
    ViewData["Title"] = "ورود مدیریت";
}

<div class="min-vh-100 d-flex align-items-center justify-content-center bg-light auth-background overflow-hidden" dir="rtl">
    <div class="floating-orb orb-primary"></div>
    <div class="floating-orb orb-secondary"></div>
    <div class="card border-0 shadow-lg rounded-4 auth-card fade-in">
        <div class="card-body p-4 p-md-5">
            <div class="text-center mb-4">
                <div class="d-inline-flex align-items-center justify-content-center rounded-circle bg-success-subtle text-success fs-2 mb-3 brand-icon brand-pulse">
                    <i class="bi bi-tree"></i>
                </div>
                <h1 class="h4 fw-bold mb-1">آتلیه چوب</h1>
                <p class="text-muted mb-0">ورود به پنل مدیریت</p>
            </div>

            @if (!ViewData.ModelState.IsValid)
            {
                <div class="alert alert-danger small mb-4" role="alert">
                    <div class="fw-semibold mb-2">لطفاً موارد زیر را بررسی کنید:</div>
                    <ul class="mb-0 ps-3">
                        @foreach (var entry in ViewData.ModelState.Values)
                        {
                            foreach (var error in entry.Errors)
                            {
                                <li>@error.ErrorMessage</li>
                            }
                        }
                    </ul>
                </div>
            }

            <form method="post" action="/Admin/Auth/Login" class="needs-validation" novalidate>
                <div class="mb-3">
                    <label for="UserName" class="form-label">نام کاربری</label>
                    <input id="UserName" name="UserName" value="@Model?.UserName" class="form-control form-control-lg auth-input" autocomplete="username" required />
                </div>
                <div class="mb-3">
                    <label for="Password" class="form-label">رمز عبور</label>
                    <input id="Password" name="Password" type="password" class="form-control form-control-lg auth-input" autocomplete="current-password" required />
                </div>
                <div class="align-items-center justify-content-between mb-4">
                    <div class="form-check">
                        <input id="RememberMe" name="RememberMe" type="checkbox" value="true" class="form-check-input" />
                        <label for="RememberMe" class="form-check-label">مرا به خاطر بسپار</label>
                    </div>
                    <span class="text-muted small">اگر رمز عبور را فراموش کرده‌اید با مدیر فروش تماس بگیرید.</span>
                </div>
                <button type="submit" class="btn btn-success w-100 btn-lg d-flex align-items-center justify-content-center" id="loginButton">
                    <span class="spinner-border spinner-border-sm ms-2 d-none" role="status" aria-hidden="true"></span>
                    <span class="button-text">ورود</span>
                </button>
                <p class="text-muted small mt-3 mb-0">برای ورود، نام کاربری و رمز عبور خود را دقیق وارد کنید.</p>
            </form>
        </div>
    </div>
</div>

<style>
    .auth-card {
        width: min(420px, 100%);
        background: #ffffff;
        position: relative;
        z-index: 1;
    }

    .fade-in {
        animation: fadeInUp 0.6s ease-out both;
    }

    @@keyframes fadeInUp {
        from {
            opacity: 0;
            transform: translateY(12px);
        }
        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    .auth-input:focus {
        border-color: #3d8b40;
        box-shadow: 0 0 0 0.25rem rgba(61, 139, 64, 0.2);
    }

    .brand-icon {
        width: 72px;
        height: 72px;
    }

    .brand-pulse {
        animation: softPulse 2.2s ease-in-out infinite;
    }

    .auth-background {
        background: radial-gradient(circle at top, #f7fbf7 0%, #f2f6f3 45%, #edf2ef 100%);
    }

    .floating-orb {
        position: absolute;
        width: 160px;
        height: 160px;
        border-radius: 999px;
        filter: blur(0px);
        opacity: 0.35;
        animation: floaty 7s ease-in-out infinite;
    }

    .orb-primary {
        top: 8%;
        left: 12%;
        background: radial-gradient(circle, rgba(61, 139, 64, 0.35), rgba(61, 139, 64, 0.05));
    }

    .orb-secondary {
        bottom: 10%;
        right: 8%;
        width: 200px;
        height: 200px;
        animation-delay: 1.2s;
        background: radial-gradient(circle, rgba(25, 135, 84, 0.35), rgba(25, 135, 84, 0.05));
    }

    @@keyframes softPulse {
        0% {
            transform: scale(1);
            box-shadow: 0 0 0 0 rgba(25, 135, 84, 0.25);
        }
        50% {
            transform: scale(1.05);
            box-shadow: 0 0 0 12px rgba(25, 135, 84, 0);
        }
        100% {
            transform: scale(1);
            box-shadow: 0 0 0 0 rgba(25, 135, 84, 0);
        }
    }

    @@keyframes floaty {
        0%,
        100% {
            transform: translateY(0);
        }
        50% {
            transform: translateY(-18px);
        }
    }
</style>

<script>
    (() => {
        const form = document.querySelector("form");
        const button = document.getElementById("loginButton");
        const spinner = button?.querySelector(".spinner-border");
        const buttonText = button?.querySelector(".button-text");

        if (form && button && spinner && buttonText) {
            form.addEventListener("submit", () => {
                button.disabled = true;
                spinner.classList.remove("d-none");
                buttonText.textContent = "در حال ورود...";
            });
        }
    })();
</script>
