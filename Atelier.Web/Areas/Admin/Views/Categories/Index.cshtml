@model IReadOnlyList<Atelier.Web.Areas.Admin.ViewModels.CategoryListItemViewModel>
@{
    Layout = "/Areas/Admin/Views/Shared/_AdminLayout.cshtml";
    ViewData["Title"] = "مدیریت دسته‌بندی‌ها";
}

<div class="container-fluid py-4" dir="rtl">
    <div class="admin-card mb-4">
        <div class="d-flex flex-column flex-lg-row align-items-lg-center justify-content-between gap-3">
            <div>
                <h1 class="h5 fw-bold mb-1">دسته‌بندی‌ها</h1>
                <p class="text-muted mb-0">دسته‌بندی‌های محصولات را مدیریت کنید.</p>
            </div>
            <a class="btn btn-success admin-action-btn" asp-area="Admin" asp-controller="Categories" asp-action="Create">
                <i class="bi bi-plus-circle"></i>
                افزودن دسته‌بندی
            </a>
        </div>
    </div>

    @if (TempData["SuccessMessage"] is string successMessage)
    {
        <div class="alert alert-success admin-alert" role="alert">
            <i class="bi bi-check-circle"></i>
            <span>@successMessage</span>
        </div>
    }

    @if (TempData["ErrorMessage"] is string errorMessage)
    {
        <div class="alert alert-danger admin-alert" role="alert">
            <i class="bi bi-exclamation-circle"></i>
            <span>@errorMessage</span>
        </div>
    }

    @if (!Model.Any())
    {
        <div class="admin-card text-center">
            <h2 class="h6 fw-bold mb-2">هنوز دسته‌بندی‌ای ثبت نشده است.</h2>
            <p class="text-muted mb-3">برای شروع، یک دسته‌بندی جدید اضافه کنید.</p>
            <a class="btn btn-success admin-action-btn" asp-area="Admin" asp-controller="Categories" asp-action="Create">
                افزودن دسته‌بندی
            </a>
        </div>
    }
    else
    {
        <div class="admin-card">
            <div class="table-responsive">
                <table class="table align-middle">
                    <thead class="table-light">
                        <tr>
                            <th>عنوان دسته‌بندی</th>
                            <th>اسلاگ</th>
                            <th>وضعیت</th>
                            <th class="text-end">عملیات</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var category in Model)
                        {
                            <tr>
                                <td class="fw-semibold">@category.Name</td>
                                <td class="text-muted">@category.Slug</td>
                                <td>
                                    @if (category.IsActive)
                                    {
                                        <span class="badge bg-success">فعال</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-secondary">غیرفعال</span>
                                    }
                                </td>
                                <td class="text-end">
                                    <a class="btn btn-outline-primary btn-sm" asp-area="Admin" asp-controller="Categories" asp-action="Edit" asp-route-id="@category.Id">ویرایش</a>
                                    <form method="post" asp-area="Admin" asp-controller="Categories" asp-action="Delete" asp-route-id="@category.Id" class="d-inline" onsubmit="return confirm('آیا از حذف این دسته‌بندی مطمئن هستید؟');">
                                        @Html.AntiForgeryToken()
                                        <button type="submit" class="btn btn-outline-danger btn-sm">حذف</button>
                                    </form>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    }
</div>
