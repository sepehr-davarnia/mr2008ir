@model Atelier.Web.Areas.Admin.ViewModels.VehicleEditViewModel
@Html.AntiForgeryToken()
<input type="hidden" asp-for="Id" />
<div asp-validation-summary="ModelOnly" class="text-danger"></div>
<div class="row g-3">
    <div class="col-md-6"><label asp-for="Make" class="form-label"></label><input asp-for="Make" class="form-control" /></div>
    <div class="col-md-6"><label asp-for="Model" class="form-label"></label><input asp-for="Model" class="form-control" /></div>
    <div class="col-md-6"><label asp-for="YearFrom" class="form-label"></label><input asp-for="YearFrom" class="form-control" /></div>
    <div class="col-md-6"><label asp-for="YearTo" class="form-label"></label><input asp-for="YearTo" class="form-control" /></div>
    <div class="col-md-6"><label asp-for="Engine" class="form-label"></label><input asp-for="Engine" class="form-control" /></div>
    <div class="col-md-6"><label asp-for="Trim" class="form-label"></label><input asp-for="Trim" class="form-control" /></div>
    <div class="col-12"><label asp-for="Slug" class="form-label"></label><input asp-for="Slug" class="form-control" dir="ltr" /></div>
    <div class="col-12 form-check"><input asp-for="IsActive" class="form-check-input" /><label asp-for="IsActive" class="form-check-label"></label></div>
</div>
<div class="d-flex gap-2 mt-4"><button class="btn btn-success" type="submit">ذخیره</button><a class="btn btn-outline-secondary" asp-action="Index">بازگشت</a></div>
