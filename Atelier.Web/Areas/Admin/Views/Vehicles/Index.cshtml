@model IReadOnlyList<Atelier.Web.Areas.Admin.ViewModels.VehicleListItemViewModel>
@{ Layout = "/Areas/Admin/Views/Shared/_AdminLayout.cshtml"; ViewData["Title"] = "خودروها و سازگاری"; }
<div class="container-fluid py-4" dir="rtl">
    <div class="d-flex justify-content-between align-items-center mb-4"><div><h1 class="h5 fw-bold">خودروها</h1><p class="text-muted mb-0">سال، موتور و تریم‌های قابل اتصال به محصولات</p></div><a class="btn btn-success" asp-action="Create">خودروی جدید</a></div>
    @if (TempData["SuccessMessage"] is string message) { <div class="alert alert-success">@message</div> }
    <div class="admin-form-card table-responsive"><table class="table align-middle mb-0"><thead><tr><th>مشخصات</th><th>اسلاگ</th><th>محصولات</th><th>وضعیت</th><th></th></tr></thead><tbody>
    @foreach (var item in Model) { <tr><td>@item.Label</td><td dir="ltr">@item.Slug</td><td>@item.ProductCount</td><td>@(item.IsActive ? "فعال" : "غیرفعال")</td><td><a class="btn btn-sm btn-outline-secondary" asp-action="Edit" asp-route-id="@item.Id">ویرایش</a></td></tr> }
    </tbody></table></div>
</div>
